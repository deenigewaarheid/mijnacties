{
  "name": "mail-analyzer-full",
  "version": "1.0.0",
  "description": "Complete Mail Analyzer webapp met Gmail API en Claude AI",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },
  "keywords": [
    "mail",
    "analyzer",
    "gmail",
    "claude",
    "ai"
  ],
  "author": "Mohamed",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "pdf-parse": "^1.1.4"
  }
}
